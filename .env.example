# Django
DJANGO_SECRET_KEY=use-django.core.management.utils.get_random_secret_key-to-generate
DJANGO_DEBUG=True

# PostgreSQL
DB_NAME=aurora
DB_USER=aurora_user
DB_PASSWORD=replace-with-strong-password-for-production
DB_HOST=127.0.0.1
DB_PORT=5432

# Symmetric encryption for OAuth tokens stored in DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# Strava OAuth
# Register your app at https://www.strava.com/settings/api
# Callback Domain in Strava settings must be: localhost (for dev) or your prod domain
STRAVA_CLIENT_ID=replace-with-strava-client-id
STRAVA_CLIENT_SECRET=replace-with-strava-client-secret
STRAVA_REDIRECT_URI=http://localhost:8000/api/workouts/strava/callback/